# Public env. Copy to .env.local for dev; set the same keys on Vercel for
# the deployed env. Both must be NEXT_PUBLIC_* so they're available in the
# browser bundle.
#
# Dev:   http://localhost:3000/api  and  http://localhost:5173
# Prod:  https://ems-backend.onrender.com/api  and  https://ems-frontend-XX.vercel.app

NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_APP_URL=http://localhost:5173
